generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                          String                       @id @default(uuid())
  name                        String?
  email                       String                       @unique
  emailVerified               DateTime?
  image                       String?
  member                      Role                         @default(MEMBER)
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  accounts                    Account[]
  updatedBlogs                Blog[]                       @relation("BlogUpdatedBy")
  emailNotificationPreference EmailNotificationPreference?
  roadmapVotes                RoadmapVote[]
  updatedSermons              Sermon[]                     @relation("SermonUpdatedBy")
  sessions                    Session[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Media {
  id         String   @id @default(uuid())
  type       String?
  name       String
  link       String   @unique
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Image {
  id          String   @id @default(uuid())
  type        String
  filename    String
  event       String
  bucket      String
  url         String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Events {
  id          Int      @id @default(autoincrement())
  event       String
  date        String[] @default(["", ""])
  location    String
  description Json
  monthly     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EventMedia {
  id          Int      @id @default(autoincrement())
  event       String   @unique
  date        DateTime
  location    String?
  description String?
  images      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NewsletterEmail {
  email String @id
}

model Sermon {
  id              Int      @id @default(autoincrement())
  videoUrl        String   @unique
  sermonTitle     String
  tags            String[]
  likes           Int?
  sermonResources String[] @default([])
  thumbnail       String?  @default("")
  summary         String   @default("")
  aiBreakdown     String   @default("")
  videoTranscript String   @default("")
  speaker         String   @default("")
  hasNotes        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  updatedById     String?
  updatedBy       User?    @relation("SermonUpdatedBy", fields: [updatedById], references: [id])
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  likes     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Blog {
  id              String       @id @default(uuid())
  blogTitle       String
  blogDescription String
  blogImage       String?
  blogContent     String
  blogAuthor      String
  category        String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  updatedById     String?
  updatedBy       User?        @relation("BlogUpdatedBy", fields: [updatedById], references: [id])
  series          Blog_Series?
}

model Blog_Series {
  id        Int      @id @default(autoincrement())
  blogId    String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blog      Blog?    @relation(fields: [blogId], references: [id])
}

model Notification {
  id                   String   @id @default(uuid())
  notification         String
  shouldNotify         Boolean
  notificationDuration String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model RoadmapVote {
  id            String   @id @default(uuid())
  linearIssueId String
  userId        String
  voteType      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([linearIssueId, userId])
}

model Feedback {
  id           Int      @id @default(autoincrement())
  name         String?
  email        String?
  category     String?
  message      String
  feedbackFrom String?
  createdAt    DateTime @default(now())
}

model SiteSettings {
  id                Int      @id @default(autoincrement())
  churchName        String   @default("Church Admin")
  description       String   @default("")
  contactEmail      String?
  contactPhone      String?
  address           String?
  socialLinks       Json?
  primaryColor      String   @default("#0088FE")
  logoUrl           String?
  allowRegistration Boolean  @default(true)
  selectedModel     String?
  autoSelectModel   Boolean  @default(true)
  updatedAt         DateTime @updatedAt
  updatedBy         String?
}

model AIModelStatus {
  id            String    @id
  available     Boolean?
  hasBeenTested Boolean   @default(false)
  lastChecked   DateTime?
  lastFailure   DateTime?
  errorCount    Int       @default(0)
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AdminActivity {
  id         String   @id @default(uuid())
  userId     String
  section    String
  lastViewed DateTime @default(now())

  @@unique([userId, section])
}

model EmailNotificationPreference {
  id                  String   @id @default(uuid())
  userId              String   @unique
  notifyNewUsers      Boolean  @default(true)
  notifyNewBlogs      Boolean  @default(true)
  notifyNewSermons    Boolean  @default(true)
  notifyNewEvents     Boolean  @default(true)
  notifyNewFeedback   Boolean  @default(true)
  notifyEditedBlogs   Boolean  @default(true)
  notifyEditedSermons Boolean  @default(true)
  notifyEditedEvents  Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  MEMBER
  MINISTER
  ADMIN_GENERAL
  ADMIN_MODERATE
  ADMIN_FULL
  OWNER
}
