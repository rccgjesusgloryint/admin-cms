{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "church-admin-cmd",
  "compatibility_date": "2025-11-27",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "minify": true,
  "routes": [
    {
      "pattern": "admin.jesusgloryintl.com",
      "zone_name": "jesusgloryintl.com"
    }
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "r2_buckets": [
    {
      "binding": "NEXT_INC_CACHE_R2_BUCKET",
      "bucket_name": "cache"
    }
  ],
  "workers_dev": true,
  "preview_urls": true,
  "vars": {
    "ADMIN_URL": "https://admin.jesusgloryintl.com",
    "AUTH_TRUST_HOST": "true",
    "BASE_URL": "https://admin.jesusgloryintl.com",
    "CLOUDFARE_IMAGE_URL": "https://img.jesusgloryintl.com",
    "NEXTAUTH_URL": "https://admin.jesusgloryintl.com",
    "R2_BUCKET": "church-media",
    "YOUTUBE_API_BASE_URL": "https://www.googleapis.com/youtube/v3",
    "DATABASE_URL": "prisma://accelerate.prisma-data.net/?api_key=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..-4ribUIpxqQ1XyfV-bBVRabdz-gN49fpOUxPc8TDr4I"
  }
}
